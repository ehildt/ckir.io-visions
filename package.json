{
  "name": "@ckir.io/visions",
  "description": "ckir.io/visions is an AI-powered image analysis microservice, originating from the ckir project collection.",
  "version": "1.1.0",
  "license": "MIT",
  "type": "module",
  "author": {
    "email": "eugen.hildt@gmail.com",
    "name": "Eugen Hildt"
  },
  "bugs": {
    "email": "eugen.hildt@gmail.com"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build --path ./tsconfig.build.json",
    "build:prod": "nest build --path ./tsconfig.build.prod.json",
    "depcheck": "npx depcheck .",
    "depcruise": "npx dependency-cruiser -c .depcruise.mjs --ts-config tsconfig.json src",
    "lint": "eslint ./src",
    "lint-staged": "npx lint-staged --allow-empty",
    "ncu:update": "npx npm-check-updates -u --format group",
    "ncu:interactive": "npx npm-check-updates -u --interactive --format group",
    "ncu:validate": "npx npm-check-updates -e 2 --packageFile=./package.json",
    "start": "nest start",
    "start:debug": "nest start --debug --watch  --preserveWatchOutput",
    "start:dev": "dotenv -e ./.env -- nest start --watch  --preserveWatchOutput",
    "start:node": "node dist/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint:unused": "npx ts-unused-exports ./tsconfig.exclude.json --maxIssues=0"
  },
  "dependencies": {
    "@ehildt/ckir-helpers": "^1.3.2",
    "@ehildt/nestjs-bullmq": "^1.1.2",
    "@ehildt/nestjs-bullmq-logger": "^1.1.0",
    "@ehildt/nestjs-config-factory": "^1.1.2",
    "@ehildt/nestjs-ollama": "^1.2.0",
    "@ehildt/nestjs-socket.io": "^1.3.3",
    "@fastify/compress": "^8.3.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/platform-fastify": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "bullmq": "^5.73.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "npm": "^11.12.1",
    "ollama": "^0.6.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^17.3.10",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^20.0.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "ts-unused-exports": "^11.0.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
