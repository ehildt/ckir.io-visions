generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DlqStatus {
  PENDING_RETRY
  REINSERTED
  ARCHIVED
  PENDING_DELETION
}

model VisionsDlq {
  requestId      String    @id @db.VarChar(255)
  queueName      String    @db.VarChar(100)
  jobId          String?   @db.VarChar(255)
  status         DlqStatus @default(PENDING_RETRY)
  payload        Json      @default(dbgenerated())
  retryConfig    Json?
  failedReason   String?
  failedAt       DateTime?
  attemptsMade   Int       @default(1)
  totalAttempts  Int       @default(1)
  failureHistory Json?
  nextRetryAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  @@map("visions_dlq")
}
